          "name": "TC-06 | GET /rates?base=USD - Tasas con base USD",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rates?base=USD",
              "host": ["{{baseUrl}}"],
              "path": ["rates"],
