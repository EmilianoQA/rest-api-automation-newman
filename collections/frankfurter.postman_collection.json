    {
      "name": "05 - Single Rate",
      "description": "Validates the /rate/{base}/{quote} endpoint.",
      "item": [
        {
          "name": "TC-18 | GET /rate/EUR/USD - Par de monedas válido",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rate/EUR/USD",
              "host": ["{{baseUrl}}"],
              "path": ["rate", "EUR", "USD"]
