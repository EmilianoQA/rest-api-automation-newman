                  "});",
                  "",
                  "pm.test('Retorna un objeto con datos de la moneda', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('object');",
                  "    pm.expect(Object.keys(body).length).to.be.above(0);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-04 | GET /currency/INVALID - Código de moneda inexistente",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/currency/INVALID",
              "host": ["{{baseUrl}}"],
              "path": ["currency", "INVALID"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 404 para moneda inexistente', function () {",
                  "    pm.response.to.have.status(404);",
                  "});",
