            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Todos los items tienen base USD', function () {",
                  "    const body = pm.response.json();",
                  "    body.forEach(function(item) {",
                  "        pm.expect(item.base).to.equal('USD');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Ningún item tiene quote USD (no se cotiza contra sí mismo)', function () {",
                  "    const body = pm.response.json();",
                  "    body.forEach(function(item) {",
                  "        pm.expect(item.quote).to.not.equal('USD');",
                  "    });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-07 | GET /rates?base=USD&quotes=MXN,BRL - Filtrar monedas específicas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rates?base=USD&quotes=MXN,BRL",
              "host": ["{{baseUrl}}"],
              "path": ["rates"],
              "query": [
                { "key": "base", "value": "USD" },
                { "key": "quotes", "value": "MXN,BRL" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Retorna exactamente 2 items: MXN y BRL', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.lengthOf(2);",
                  "    const quotes = body.map(function(i) { return i.quote; });",
                  "    pm.expect(quotes).to.include('MXN');",
                  "    pm.expect(quotes).to.include('BRL');",
                  "});",
                  "",
                  "pm.test('MXN mayor a 1 respecto al USD (lógica de negocio)', function () {",
                  "    const body = pm.response.json();",
                  "    const mxn = body.find(function(i) { return i.quote === 'MXN'; });",
                  "    pm.expect(mxn.rate).to.be.above(1);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-08 | GET /rates?base=INVALID - Base inválida",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rates?base=INVALID",
              "host": ["{{baseUrl}}"],
