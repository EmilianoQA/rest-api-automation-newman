{
  "info": {
    "name": "Frankfurter API - Test Suite",
    "_postman_id": "frankfurter-api-test-suite-v1",
    "description": "Automated test suite for Frankfurter Exchange Rates API v2.\nCovers: currencies, latest rates, historical rates, time series and single rate pair.\n\nBase URL: https://api.frankfurter.dev/v2\nNo authentication required.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "01 - Currencies",
      "description": "Validates the /currencies and /currency endpoints.",
      "item": [
        {
          "name": "TC-01 | GET /currencies - Lista completa de monedas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/currencies",
              "host": ["{{baseUrl}}"],
              "path": ["currencies"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Content-Type es application/json', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "pm.test('El body es un array no vacío', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "    pm.expect(body.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Cada elemento tiene iso_code y name', function () {",
                  "    const body = pm.response.json();",
                  "    body.forEach(function(currency) {",
                  "        pm.expect(currency).to.have.property('iso_code');",
                  "        pm.expect(currency).to.have.property('name');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Contiene monedas clave: USD, EUR, MXN, BRL', function () {",
                  "    const body = pm.response.json();",
                  "    const codes = body.map(function(c) { return c.iso_code; });",
                  "    pm.expect(codes).to.include('USD');",
                  "    pm.expect(codes).to.include('EUR');",
                  "    pm.expect(codes).to.include('MXN');",
                  "    pm.expect(codes).to.include('BRL');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "TC-02 | GET /currencies?scope=all - Incluye monedas archivadas",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/currencies?scope=all",
              "host": ["{{baseUrl}}"],
              "path": ["currencies"],
              "query": [{ "key": "scope", "value": "all" }]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('scope=all retorna más monedas que la lista base', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "    pm.expect(body.length).to.be.above(30);",
                  "});"
