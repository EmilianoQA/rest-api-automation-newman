    {
      "name": "02 - Latest Rates",
      "description": "Validates current exchange rates.",
      "item": [
        {
          "name": "TC-05 | GET /rates - Tasas actuales con base default (EUR)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rates",
              "host": ["{{baseUrl}}"],
              "path": ["rates"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('El body es un array no vacío', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "    pm.expect(body.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Cada elemento tiene date, base, quote y rate', function () {",
                  "    const body = pm.response.json();",
                  "    const item = body[0];",
                  "    pm.expect(item).to.have.property('date');",
                  "    pm.expect(item).to.have.property('base');",
                  "    pm.expect(item).to.have.property('quote');",
                  "    pm.expect(item).to.have.property('rate');",
                  "});",
                  "",
                  "pm.test('Base default es EUR', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body[0].base).to.equal('EUR');",
                  "});",
                  "",
                  "pm.test('Los rates son números positivos', function () {",
                  "    const body = pm.response.json();",
                  "    body.forEach(function(item) {",
                  "        pm.expect(item.rate).to.be.a('number').and.above(0);",
                  "    });",
                  "});",
                  "",
                  "pm.test('El campo date tiene formato YYYY-MM-DD', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body[0].date).to.match(/^\\d{4}-\\d{2}-\\d{2}$/);",
                  "});"
                ]
              }
            }
          ]
        },
