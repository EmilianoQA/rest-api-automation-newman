    {
      "name": "04 - Time Series",
      "description": "Validates exchange rates over a date range.",
      "item": [
        {
          "name": "TC-14 | GET /rates?from=2024-01-01&to=2024-01-31 - Serie temporal de un mes",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/rates?from=2024-01-01&to=2024-01-31&quotes=USD",
              "host": ["{{baseUrl}}"],
              "path": ["rates"],
              "query": [
                { "key": "from", "value": "2024-01-01" },
                { "key": "to", "value": "2024-01-31" },
                { "key": "quotes", "value": "USD" }
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Retorna un array con múltiples entradas (días hábiles)', function () {",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.be.an('array');",
                  "    pm.expect(body.length).to.be.above(1);",
                  "});",
                  "",
                  "pm.test('Cada item tiene date, base, quote y rate', function () {",
                  "    const body = pm.response.json();",
                  "    body.forEach(function(item) {",
                  "        pm.expect(item).to.have.property('date');",
                  "        pm.expect(item).to.have.property('base');",
                  "        pm.expect(item).to.have.property('quote');",
                  "        pm.expect(item).to.have.property('rate');",
                  "    });",
                  "});",
                  "",
                  "pm.test('Las fechas están dentro del rango solicitado', function () {",
                  "    const body = pm.response.json();",
                  "    body.forEach(function(item) {",
                  "        pm.expect(item.date >= '2024-01-01').to.be.true;",
                  "        pm.expect(item.date <= '2024-01-31').to.be.true;",
                  "    });",
                  "});"
                ]
              }
            }
          ]
